{
  "name": "astro-x402",
  "version": "0.1.0",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup",
    "watch": "tsc --watch",
    "format": "prettier -c .prettierrc --write \"**/*.{ts,js,cjs,json,md}\"",
    "format:check": "prettier -c .prettierrc --check \"**/*.{ts,js,cjs,json,md}\"",
    "lint": "eslint . --ext .ts --fix",
    "lint:check": "eslint . --ext .ts"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "x402",
    "payment",
    "middleware"
  ],
  "license": "Apache-2.0",
  "author": "Shinya Fujino",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morinokami/astro-x402.git"
  },
  "description": "Astro middleware integration for the x402 Payment Protocol.",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "astro": "^6.3.1",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "3.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@x402/core": "^2.11.0",
    "@x402/extensions": "^2.11.0"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "@x402/paywall": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/svm": "^2.11.0"
  },
  "peerDependenciesMeta": {
    "@x402/paywall": {
      "optional": true
    },
    "@x402/evm": {
      "optional": true
    },
    "@x402/svm": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ]
}

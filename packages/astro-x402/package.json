{
  "name": "astro-x402",
  "version": "0.2.0",
  "description": "Astro middleware integration for the x402 Payment Protocol.",
  "keywords": [
    "astro",
    "astro-integration",
    "middleware",
    "payment",
    "x402"
  ],
  "homepage": "https://github.com/morinokami/astro-x402#readme",
  "bugs": {
    "url": "https://github.com/morinokami/astro-x402/issues"
  },
  "license": "Apache-2.0",
  "author": "Shinya Fujino <shf0811@gmail.com> (https://github.com/morinokami)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morinokami/astro-x402.git",
    "directory": "packages/astro-x402"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check"
  },
  "dependencies": {
    "@x402/core": "catalog:",
    "@x402/extensions": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "astro": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@x402/evm": "^2.11.0",
    "@x402/paywall": "^2.11.0",
    "@x402/svm": "^2.11.0",
    "astro": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@x402/paywall": {
      "optional": true
    },
    "@x402/evm": {
      "optional": true
    },
    "@x402/svm": {
      "optional": true
    }
  }
}
